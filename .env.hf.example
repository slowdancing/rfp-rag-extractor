# ===== GCP VM(L4 GPU) HuggingFace 설정 =====
# VM 에서: cp .env.hf.example .env  후 사용

# ---- provider: 둘 다 HF (자체 호스팅) ----
LLM_PROVIDER=huggingface
EMBEDDING_PROVIDER=huggingface

# ---- HuggingFace 모델 ----
HF_EMBEDDING_MODEL=BAAI/bge-m3              # 한국어 강함, 1024차원
HF_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct      # L4 24GB 에 bf16 적재 가능
HF_DEVICE=cuda

# ---- OpenAI (비교 실험용으로 함께 쓸 경우만 채움) ----
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- Vector store ----
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=rfp_documents            # 모델명이 자동으로 접미사로 붙어 분리됨

# ---- Chunking / Retrieval ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5
RETRIEVAL_MODE=hybrid

# ---- Paths ----
DATA_RAW_DIR=./data/raw
DATA_METADATA_DIR=./data/metadata
