# ===== Copy this file to .env and fill in your values =====
# cp .env.example .env   (Windows PowerShell: Copy-Item .env.example .env)

# ---- LLM / Embedding provider ----
# 사용할 백엔드 선택: "openai" (1단계) 또는 "huggingface" (2단계, GCP VM)
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# ---- OpenAI ----
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-5-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- HuggingFace (2단계: GCP VM + L4 GPU 에서 사용) ----
# 확정 모델(results/model_decision.md): EXAONE-3.5-7.8B + bge-m3
#   ※ 실제 배포는 Ollama 경로(.env.ollama.example) 사용 — torch 불필요
HF_LLM_MODEL=LGAI-EXAONE/EXAONE-3.5-7.8B-Instruct
HF_EMBEDDING_MODEL=BAAI/bge-m3
HF_DEVICE=cuda

# ---- Vector store ----
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=rfp_documents

# ---- Chunking ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# ---- Retrieval ----
TOP_K=5

# ---- Paths ----
DATA_RAW_DIR=./data/raw
DATA_METADATA_DIR=./data/metadata
