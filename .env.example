# ===== Copy this file to .env and fill in your values =====
# cp .env.example .env   (Windows PowerShell: Copy-Item .env.example .env)

# ---- LLM / Embedding provider ----
# 사용할 백엔드 선택: "openai" (1단계) 또는 "huggingface" (2단계, GCP VM)
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# ---- OpenAI ----
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ---- HuggingFace (2단계: GCP VM + L4 GPU 에서 사용) ----
# 예) HF_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
#     HF_EMBEDDING_MODEL=BAAI/bge-m3   (한국어 포함 multilingual 권장)
HF_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct
HF_EMBEDDING_MODEL=BAAI/bge-m3
HF_DEVICE=cuda

# ---- Vector store ----
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=rfp_documents

# ---- Chunking ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# ---- Retrieval ----
TOP_K=5

# ---- Paths ----
DATA_RAW_DIR=./data/raw
DATA_METADATA_DIR=./data/metadata
