# ===== Ollama(올라마) 설정 — GCP VM(GPU) =====
# Ollama가 OpenAI 호환 API를 제공하므로, provider=openai + base_url 만 Ollama로 돌린다.
# → Python 에 torch/transformers 불필요 (Ollama 바이너리가 모델 실행).
# VM 에서: cp .env.ollama.example .env

# LLM·임베딩 모두 Ollama 로 (OpenAI 호환 엔드포인트)
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama                  # Ollama 는 키 검사 안 함(아무 값)

# Ollama 모델명 (ollama pull 로 받은 이름과 일치)
OPENAI_LLM_MODEL=exaone3.5:7.8b       # 확정: 한국어 특화, LLM비교 1위(0.533) — results/model_decision.md
OPENAI_EMBEDDING_MODEL=bge-m3          # 확정: 한국어 강한 임베딩(OpenAI 압도)
# 낮은 온도 = 문서에 충실·형식 준수(요약/추출에 중요). Ollama 기본(0.8)은 헛소리 위험.
OPENAI_TEMPERATURE=0.2

# Vector store
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=rfp_documents        # 임베딩 모델명이 자동 접미사로 붙어 분리됨

# Chunking / Retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5
RETRIEVAL_MODE=hybrid

# 나라장터 실시간 폴백 (로컬 DB에 적합 공고 없을 때 조달청 API 조회)
# data.go.kr '입찰공고정보서비스' 인증키 발급 후 아래 채우면 켜짐(옵트인).
NARA_FALLBACK=false
NARA_API_KEY=
NARA_SEARCH_DAYS=30

# 적격성 판정 전용 LLM (옵트인)
# EXAONE-7.8B는 근거기반 자격판정에서 환각이 잦아, 이 과제만 gpt-5-mini(공식 OpenAI)로 라우팅.
# 아래 실제 OpenAI 키를 채우면 적격성만 gpt-5-mini로, 비우면 EXAONE로 폴백.
ELIGIBILITY_OPENAI_KEY=
ELIGIBILITY_OPENAI_MODEL=gpt-5-mini
