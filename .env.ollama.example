# ===== Ollama(올라마) 설정 — GCP VM(GPU) =====
# Ollama가 OpenAI 호환 API를 제공하므로, provider=openai + base_url 만 Ollama로 돌린다.
# → Python 에 torch/transformers 불필요 (Ollama 바이너리가 모델 실행).
# VM 에서: cp .env.ollama.example .env

# LLM·임베딩 모두 Ollama 로 (OpenAI 호환 엔드포인트)
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama                  # Ollama 는 키 검사 안 함(아무 값)

# Ollama 모델명 (ollama pull 로 받은 이름과 일치)
OPENAI_LLM_MODEL=qwen2.5:7b            # 한국어 가능 LLM
OPENAI_EMBEDDING_MODEL=bge-m3          # 한국어 강한 임베딩

# Vector store
VECTOR_STORE=chroma
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=rfp_documents        # 임베딩 모델명이 자동 접미사로 붙어 분리됨

# Chunking / Retrieval
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=5
RETRIEVAL_MODE=hybrid
